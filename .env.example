# Michael's Spotify app credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# OpenAI key (optional — there's a Supabase fallback in api/openai.js)
# OPENAI_API_KEY=sk-...

# Rubin's Spotify app credentials
RUBIN_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
RUBIN_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Rubin user's long-lived refresh token. Seed by visiting /api/new/rubin-oauth-callback once
# while logged into Spotify as the Rubin user, then copy the value here (and into Vercel env).
RUBIN_REFRESH_TOKEN=